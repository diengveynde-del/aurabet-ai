import React, { useState, useEffect } from 'react';
import { initializeApp } from 'firebase/app';
import { 
  getAuth, 
  signInAnonymously, 
  onAuthStateChanged, 
  signInWithCustomToken 
} from 'firebase/auth';
import { 
  getFirestore, 
  doc, 
  setDoc, 
  onSnapshot 
} from 'firebase/firestore';
import {
  BrainCircuit,
  ShieldCheck,
  Zap,
  X,
  LayoutGrid,
  User,
  Wallet,
  Activity
} from 'lucide-react';

/**
 * AURABET AI - DESIGN SYSTEM AFROFUTURISTE
 * Thème: Cyber-Dakar / Vibranium Dark
 */
const GlobalStyles = () => (
  <style>{`
    @tailwind base;
    @tailwind components;
    @tailwind utilities;

    body {
      background: radial-gradient(circle at top, #1a0525 0%, #020202 60%, #000000 100%);
      color: #f8fafc;
      margin: 0;
      min-height: 100vh;
      font-family: 'Inter', system-ui, sans-serif;
    }

    .vibranium-card {
      background: linear-gradient(145deg, rgba(30, 10, 50, 0.4), rgba(10, 10, 10, 0.6));
      border: 1px solid rgba(126, 34, 206, 0.2);
      backdrop-filter: blur(20px);
    }

    @keyframes pulse-aura {
      0% { box-shadow: 0 0 0 0 rgba(126, 34, 206, 0.4); }
      70% { box-shadow: 0 0 0 15px rgba(126, 34, 206, 0); }
      100% { box-shadow: 0 0 0 0 rgba(126, 34, 206, 0); }
    }

    .aura-active {
      animation: pulse-aura 2s infinite;
    }

    .neon-text {
      text-shadow: 0 0 10px rgba(34, 211, 238, 0.5);
    }

    input::-webkit-outer-spin-button,
    input::-webkit-inner-spin-button {
      -webkit-appearance: none;
      margin: 0;
    }
  `}</style>
);

// Firebase Safe Initialization
const firebaseConfig = typeof __firebase_config !== 'undefined' 
  ? JSON.parse(__firebase_config) 
  : { apiKey: "", authDomain: "", projectId: "aurabet-ai", storageBucket: "", messagingSenderId: "", appId: "" };

const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const appId = typeof __app_id !== 'undefined' ? __app_id : 'aurabet-prod';

export default function App() {
  const [user, setUser] = useState(null);
  const [profile, setProfile] = useState({ balance: 15000, auraScore: 720 });
  const [betSlip, setBetSlip] = useState({ active: false, team: '', odd: 1.85, amount: 1000 });
  const [toast, setToast] = useState(null);
  const [isLiveLoading, setIsLiveLoading] = useState(true);

  // Authentification & Persistence
  useEffect(() => {
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (err) { console.error("Auth Error:", err); }
    };
    initAuth();
    return onAuthStateChanged(auth, setUser);
  }, []);

  useEffect(() => {
    if (!user) return;
    const profileRef = doc(db, 'artifacts', appId, 'users', user.uid, 'data', 'profile');
    const unsubscribe = onSnapshot(profileRef, (snap) => {
      if (snap.exists()) setProfile(snap.data());
      else setDoc(profileRef, { balance: 15000, auraScore: 720 });
    });
    return () => unsubscribe();
  }, [user]);

  // Simulation de chargement du flux live
  useEffect(() => {
    const timer = setTimeout(() => setIsLiveLoading(false), 2000);
    return () => clearTimeout(timer);
  }, []);

  const triggerToast = (msg) => {
    setToast(msg);
    setTimeout(() => setToast(null), 3000);
  };

  const handlePlaceBet = async () => {
    if (betSlip.amount > profile.balance) return triggerToast("Solde insuffisant !");
    if (!user) return;

    const profileRef = doc(db, 'artifacts', appId, 'users', user.uid, 'data', 'profile');
    try {
      await setDoc(profileRef, { 
        ...profile, 
        balance: profile.balance - betSlip.amount,
        auraScore: profile.auraScore + 5 
      }, { merge: true });
      
      setBetSlip({ ...betSlip, active: false });
      triggerToast("Pari Quantum validé !");
    } catch (e) {
      triggerToast("Erreur de synchronisation");
    }
  };

  if (!user) return (
    <div className="h-screen bg-black flex flex-col items-center justify-center space-y-4">
      <GlobalStyles />
      <div className="w-10 h-10 border-2 border-[#7e22ce] border-t-transparent rounded-full animate-spin"></div>
      <p className="text-[10px] uppercase font-black tracking-[0.5em] text-[#7e22ce] animate-pulse">Connexion au Nexus...</p>
    </div>
  );

  return (
    <div className="min-h-screen pb-32">
      <GlobalStyles />
      
      {/* HEADER */}
      <header className="p-6 sticky top-0 z-50 bg-[#020202]/80 backdrop-blur-xl border-b border-[#7e22ce]/20 flex justify-between items-center">
        <div className="flex flex-col">
          <h1 className="text-2xl font-black italic tracking-tighter uppercase leading-none">
            AURA<span className="text-[#7e22ce]">BET</span>
          </h1>
          <span className="text-[7px] text-[#22d3ee] font-bold uppercase tracking-[0.4em] mt-1">AI Prediction Nexus</span>
        </div>
        <div className="vibranium-card px-5 py-2 rounded-2xl flex flex-col items-end">
          <span className="text-[7px] uppercase font-black text-[#7e22ce] mb-1">Portefeuille</span>
          <span className="text-sm font-black text-[#fbbf24]">{profile.balance.toLocaleString()} <span className="text-[9px] opacity-60">XOF</span></span>
        </div>
      </header>

      <main className="max-w-xl mx-auto p-4 space-y-6">
        {/* AURA SCORE CARD */}
        <section className="vibranium-card p-6 rounded-[2rem] flex items-center justify-between border-l-4 border-[#22d3ee]">
          <div>
            <p className="text-[9px] font-black uppercase text-white/40 tracking-widest mb-1">Votre Aura Score</p>
            <h2 className="text-3xl font-black italic neon-text text-[#22d3ee]">{profile.auraScore}</h2>
          </div>
          <div className="h-12 w-12 rounded-full border-2 border-[#22d3ee]/30 flex items-center justify-center aura-active">
            <Activity size={20} className="text-[#22d3ee]" />
          </div>
        </section>

        {/* AI ADVISOR MODULE */}
        <section className="bg-gradient-to-br from-[#121212] to-black p-8 rounded-[2.5rem] border border-[#7e22ce]/30 relative overflow-hidden group">
          <div className="absolute -right-8 -top-8 text-[#7e22ce]/10 group-hover:text-[#7e22ce]/20 transition-colors">
            <BrainCircuit size={160} />
          </div>
          <div className="flex items-center gap-3 mb-6 text-[#fbbf24]">
            <BrainCircuit size={20} />
            <span className="text-[10px] uppercase font-black tracking-widest">Conseiller IA Actif</span>
          </div>
          <p className="text-xl font-bold italic leading-tight mb-8 relative z-10">
            "Analyse terminée : <span className="text-[#22d3ee]">Hafia FC</span> maintient une domination tactique de <span className="text-[#7e22ce]">89%</span> pour le prochain quart d'heure."
          </p>
          <button 
            onClick={() => setBetSlip({ ...betSlip, active: true, team: 'Hafia FC (IA)', odd: 1.85 })}
            className="w-full bg-[#7e22ce] hover:bg-[#9333ea] py-5 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all active:scale-95 shadow-lg shadow-purple-900/40"
          >
            Miser sur l'algorithme
          </button>
        </section>

        {/* LIVE FEED SIMULATION */}
        <section className="space-y-4">
          <div className="flex justify-between items-center px-2">
            <h3 className="text-[10px] font-black uppercase tracking-[0.3em] text-white/30 italic">Live Feed</h3>
            <span className="flex items-center gap-1.5">
              <span className="w-1.5 h-1.5 bg-red-500 rounded-full animate-ping"></span>
              <span className="text-[9px] text-red-500 font-black">DIRECT</span>
            </span>
          </div>
          
          <div className="vibranium-card rounded-[2.5rem] p-6 space-y-6">
            {isLiveLoading ? (
              <div className="h-32 flex items-center justify-center opacity-20">
                <Zap size={32} className="animate-bounce" />
              </div>
            ) : (
              <div className="flex justify-around items-center">
                <div className="text-center">
                  <div className="text-xl font-black italic">HAF</div>
                  <div className="text-[8px] uppercase text-white/40 mt-1">Hafia FC</div>
                </div>
                <div className="text-4xl font-black italic text-[#7e22ce] neon-text">2 - 0</div>
                <div className="text-center">
                  <div className="text-xl font-black italic">DJO</div>
                  <div className="text-[8px] uppercase text-white/40 mt-1">Djoliba</div>
                </div>
              </div>
            )}
          </div>
        </section>
      </main>

      {/* TOAST SYSTEM */}
      {toast && (
        <div className="fixed top-24 left-1/2 -translate-x-1/2 bg-[#7e22ce] px-8 py-3 rounded-full z-[100] text-[10px] font-black uppercase tracking-widest shadow-2xl animate-bounce border border-white/10">
          {toast}
        </div>
      )}

      {/* NAVIGATION BASSE */}
      <nav className="fixed bottom-0 left-0 right-0 p-6 bg-[#020202]/90 backdrop-blur-2xl border-t border-white/5 flex justify-around items-center z-40">
        <button className="flex flex-col items-center gap-1 text-[#22d3ee]">
          <LayoutGrid size={22} /><span className="text-[7px] font-black uppercase italic">Dashboard</span>
        </button>
        <button className="flex flex-col items-center gap-1 text-white/20">
          <Zap size={22} /><span className="text-[7px] font-black uppercase italic">Live</span>
        </button>
        <div className="relative -mt-14 scale-110">
          <button className="w-16 h-16 bg-gradient-to-tr from-[#7e22ce] to-[#22d3ee] rounded-full flex items-center justify-center border-[6px] border-[#020202] shadow-2xl active:scale-90 transition-transform">
            <ShieldCheck size={28} className="text-white" />
          </button>
        </div>
        <button className="flex flex-col items-center gap-1 text-white/20">
          <Wallet size={22} /><span className="text-[7px] font-black uppercase italic">Wallet</span>
        </button>
        <button className="flex flex-col items-center gap-1 text-white/20">
          <User size={22} /><span className="text-[7px] font-black uppercase italic">Profil</span>
        </button>
      </nav>

      {/* BET SLIP MODAL */}
      {betSlip.active && (
        <div className="fixed inset-0 bg-black/90 backdrop-blur-md z-[60] flex items-center justify-center p-6 animate-in fade-in">
          <div className="vibranium-card w-full max-w-md p-8 rounded-[3rem] shadow-2xl relative overflow-hidden">
            <div className="flex justify-between items-center mb-8">
              <div className="flex flex-col">
                <span className="text-[9px] font-black text-[#22d3ee] uppercase tracking-[0.3em] mb-1">Coupon de Pari</span>
                <span className="text-[7px] text-white/40 uppercase font-bold">Nexus Transaction ID: #QA-902</span>
              </div>
              <button onClick={() => setBetSlip({ ...betSlip, active: false })} className="p-2 hover:bg-white/5 rounded-full transition-colors">
                <X size={20} className="text-white/40" />
              </button>
            </div>

            <div className="space-y-6">
              <div className="bg-white/5 p-6 rounded-3xl border border-white/5">
                <p className="text-[8px] text-[#7e22ce] font-black uppercase tracking-widest mb-1">Sélection</p>
                <p className="text-xl font-black italic uppercase">{betSlip.team}</p>
                <p className="text-xs font-bold text-[#fbbf24] mt-1">Cote : {betSlip.odd}</p>
              </div>

              <div className="flex gap-4">
                <div className="flex-1 bg-black/50 border border-white/10 p-5 rounded-3xl relative">
                  <span className="absolute top-2 left-5 text-[7px] text-white/30 font-black uppercase">Mise XOF</span>
                  <input 
                    type="number" 
                    value={betSlip.amount} 
                    onChange={(e) => setBetSlip({...betSlip, amount: parseInt(e.target.value) || 0})}
                    className="w-full bg-transparent pt-3 text-2xl font-black outline-none text-white"
                  />
                </div>
                <div className="bg-[#7e22ce]/10 border border-[#7e22ce]/20 p-5 rounded-3xl min-w-[120px] text-center flex flex-col justify-center">
                  <p className="text-[7px] text-[#fbbf24] font-black uppercase mb-1">Gain Est.</p>
                  <p className="font-black text-lg">{(betSlip.amount * betSlip.odd).toFixed(0)}</p>
                </div>
              </div>

              <button 
                onClick={handlePlaceBet}
                className="w-full bg-[#7e22ce] py-6 rounded-[2rem] font-black uppercase text-[11px] tracking-[0.2em] hover:bg-[#9333ea] transition-all shadow-xl shadow-purple-900/40"
              >
                Confirmer l'opération
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}